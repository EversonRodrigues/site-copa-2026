# ============================================================
# COPA DO MUNDO 2026 — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# ============================================================

# Porta do servidor HTTP (padrão: 3000)
PORT=3000

# Chave secreta para assinar as sessões Express
# OBRIGATÓRIO em produção: use uma string longa e aleatória
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=mude_esta_chave_para_algo_longo_e_aleatorio_em_producao

# Chave da API de futebol (não utilizada — usando TheSportsDB gratuita)
# Mantida para compatibilidade futura
API_FOOTBALL_KEY=nao_utilizado

# Caminho do arquivo SQLite (opcional)
# Em deploy com volume persistente, aponte para o mount point. Ex: /data/db.sqlite
# Padrão: database/db.sqlite (relativo à raiz do projeto)
# DB_PATH=/data/db.sqlite
