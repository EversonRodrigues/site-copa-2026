<%- include('../partials/header') %>
<div class="container container-sm">
  <h1 class="page-title">Entrar</h1>
  <% if (erro) { %><div class="alert alert-erro"><%= erro %></div><% } %>
  <form class="form-card" method="POST" action="/login">
    <div class="form-group">
      <label for="email">E-mail</label>
      <input type="email" id="email" name="email" class="form-input" required>
    </div>
    <div class="form-group">
      <label for="senha">Senha</label>
      <input type="password" id="senha" name="senha" class="form-input" required>
    </div>
    <button type="submit" class="btn btn-primary">Entrar</button>
    <p class="form-footer">Não tem conta? <a href="/cadastro">Cadastre-se</a></p>
  </form>
</div>
<%- include('../partials/footer') %>
