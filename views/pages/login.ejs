<%- include('../partials/header') %>
<div class="container container-sm">
  <div class="page-header">
    <h1 class="page-title">Entrar</h1>
    <p class="subtitle">Acesse sua conta para fazer palpites</p>
  </div>

  <% if (erro) { %>
    <div class="alert alert-erro" role="alert"><%= erro %></div>
  <% } %>

  <form class="form-card" method="POST" action="/login" novalidate>
    <div class="form-group">
      <label for="email">E-mail</label>
      <input type="email" id="email" name="email" class="form-input" autocomplete="email" required placeholder="seu@email.com">
    </div>
    <div class="form-group">
      <label for="senha">Senha</label>
      <input type="password" id="senha" name="senha" class="form-input" autocomplete="current-password" required placeholder="••••••••">
    </div>
    <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;">Entrar</button>
    <p class="form-footer">Não tem conta? <a href="/cadastro">Cadastre-se gratuitamente</a></p>
  </form>
</div>
<%- include('../partials/footer') %>
