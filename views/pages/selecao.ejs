<%- include('../partials/header') %>

<%
  const cor = selecao.cor || '#E8112D';
  const inicial = (selecao.nome || '?').charAt(0).toUpperCase();
  const provaveis = selecao.provaveisJogadores || [];
%>

<div class="container">
  <a href="/selecoes" class="link-voltar">&larr; Todas as Seleções</a>

  <!-- Hero "team card" -->
  <section class="dash-team-hero" style="--team-cor: <%= cor %>">
    <div class="dash-team-hero-bg" aria-hidden="true"></div>

    <div class="dash-team-hero-grid">
      <div class="dash-team-hero-main">
        <div class="dash-team-avatar" style="background: <%= cor %>"><%= inicial %></div>
        <div class="dash-team-meta">
          <span class="dash-eyebrow">
            <span class="dash-eyebrow-dot"></span>
            SELEÇÃO · <%= selecao.continente %>
          </span>
          <h1 class="dash-team-nome"><%= selecao.nome %></h1>
          <div class="dash-team-tags">
            <span class="badge badge-grupo">Grupo <%= selecao.grupo %></span>
            <span class="badge badge-continente"><%= selecao.continente %></span>
            <span class="badge badge-ranking">FIFA #<%= selecao.ranking_fifa %></span>
          </div>
        </div>
      </div>

      <aside class="dash-team-hero-side">
        <div class="dash-team-stat">
          <span class="dash-team-stat-label">Treinador</span>
          <span class="dash-team-stat-value"><%= selecao.treinador %></span>
        </div>
        <div class="dash-team-stat">
          <span class="dash-team-stat-label">Ranking FIFA</span>
          <span class="dash-team-stat-value dash-team-stat-num">#<%= selecao.ranking_fifa %></span>
        </div>
        <div class="dash-team-stat">
          <span class="dash-team-stat-label">Convocados (prov.)</span>
          <span class="dash-team-stat-value dash-team-stat-num"><%= provaveis.length %></span>
        </div>
      </aside>
    </div>
  </section>

  <!-- Grid de cards informacionais -->
  <section class="dash-team-grid">
    <article class="dash-team-card dash-team-card-wide">
      <header class="dash-team-card-head">
        <span class="dash-team-card-icon">⚽</span>
        <h2 class="dash-team-card-title">Estilo de Jogo</h2>
      </header>
      <p class="dash-team-card-text"><%= selecao.estilo %></p>
    </article>

    <article class="dash-team-card">
      <header class="dash-team-card-head">
        <span class="dash-team-card-icon">🏆</span>
        <h2 class="dash-team-card-title">Conquistas</h2>
      </header>
      <p class="dash-team-card-text"><%= selecao.conquistas %></p>
    </article>

    <article class="dash-team-card">
      <header class="dash-team-card-head">
        <span class="dash-team-card-icon">💡</span>
        <h2 class="dash-team-card-title">Curiosidades</h2>
      </header>
      <p class="dash-team-card-text"><%= selecao.curiosidades %></p>
    </article>

    <article class="dash-team-card dash-team-card-wide">
      <header class="dash-team-card-head">
        <span class="dash-team-card-icon">👕</span>
        <h2 class="dash-team-card-title">Prováveis Convocados</h2>
        <span class="dash-team-card-count"><%= provaveis.length %></span>
      </header>
      <% if (provaveis.length === 0) { %>
        <p class="dash-team-card-text text-muted">Lista a confirmar.</p>
      <% } else { %>
        <ul class="dash-team-roster">
          <% provaveis.forEach((j, i) => { %>
            <li class="dash-team-roster-item">
              <span class="dash-team-roster-num"><%= String(i + 1).padStart(2, '0') %></span>
              <span class="dash-team-roster-nome"><%= j %></span>
            </li>
          <% }) %>
        </ul>
      <% } %>
    </article>
  </section>
</div>
<%- include('../partials/footer') %>
