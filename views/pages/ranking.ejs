<%- include('../partials/header') %>
<div class="container">
  <h1 class="page-title">Ranking do Bolão</h1>
  <% if (ranking.length === 0) { %>
    <p class="text-muted">Nenhum palpite registrado ainda. <a href="/cadastro">Participe!</a></p>
  <% } else { %>
    <table class="tabela-ranking">
      <thead>
        <tr><th>#</th><th>Participante</th><th>Pontos</th></tr>
      </thead>
      <tbody>
        <% ranking.forEach((r, i) => { %>
          <tr class="<%= i < 3 ? 'top-' + (i+1) : '' %>">
            <td>
              <% if (i === 0) { %>🥇<% } else if (i === 1) { %>🥈<% } else if (i === 2) { %>🥉<% } else { %><%= i+1 %><% } %>
            </td>
            <td><%= r.nome %></td>
            <td><strong><%= r.total_pontos %></strong></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
</div>
<%- include('../partials/footer') %>
