<%- include('../partials/header') %>
<div class="container">
  <div class="page-header">
    <h1 class="page-title">Ranking do Bolão</h1>
    <p class="subtitle">Classificação geral dos participantes</p>
  </div>

  <% if (ranking.length === 0) { %>
    <div class="empty-state">
      <div class="empty-state-icon">🏆</div>
      <div class="empty-state-titulo">Nenhum palpite ainda</div>
      <p>Seja o primeiro! <a href="/cadastro">Cadastre-se</a> e faça seus palpites.</p>
    </div>
  <% } else { %>
    <table class="tabela-ranking" aria-label="Ranking do bolão">
      <thead>
        <tr>
          <th scope="col">#</th>
          <th scope="col">Participante</th>
          <th scope="col">Pontos</th>
        </tr>
      </thead>
      <tbody>
        <% ranking.forEach((r, i) => { %>
          <tr class="<%= i < 3 ? 'top-' + (i+1) : '' %>">
            <td>
              <span class="rank-posicao">
                <% if (i === 0) { %>🥇<% } else if (i === 1) { %>🥈<% } else if (i === 2) { %>🥉<% } else { %><%= i+1 %><% } %>
              </span>
            </td>
            <td class="rank-nome"><%= r.nome %></td>
            <td class="rank-pontos"><%= r.total_pontos %> <small style="font-size:0.7rem;color:var(--texto-terciario);font-family:var(--fonte-corpo)">pts</small></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
</div>
<%- include('../partials/footer') %>
