<%- include('../partials/header') %>

<div class="container">
  <!-- ===== HERO DASHBOARD ===== -->
  <section class="dash-hero">
    <div class="dash-hero-grid">
      <div class="dash-hero-text">
        <span class="dash-eyebrow">
          <span class="dash-eyebrow-dot"></span>
          FIFA WORLD CUP 2026™
          <span class="dash-eyebrow-dot"></span>
        </span>

        <h1 class="dash-titulo">
          THE BIGGEST<br>
          <span class="dash-titulo-accent">WORLD CUP</span><br>
          EVER PLAYED
        </h1>
        <p class="dash-sub">EUA &middot; Canadá &middot; México &middot; Junho — Julho 2026</p>

        <div class="dash-acoes">
          <a href="/jogos" class="btn btn-primary">⚽ Ver Jogos</a>
          <a href="/ranking" class="btn btn-outline">🏆 Ranking</a>
          <% if (!usuario) { %>
            <a href="/cadastro" class="btn btn-ghost">🎯 Participar</a>
          <% } %>
        </div>
      </div>

      <aside class="dash-hero-side">
        <div class="dash-countdown-card" id="countdown-container">
          <div class="dash-card-label">
            <span class="pulse-dot"></span>
            KICK-OFF FIFA 2026
          </div>
          <div class="dash-countdown-grid" id="countdown">
            <div class="cd-cell"><span class="cd-val" id="cd-dias">--</span><span class="cd-unit">dias</span></div>
            <div class="cd-cell"><span class="cd-val" id="cd-horas">--</span><span class="cd-unit">hrs</span></div>
            <div class="cd-cell"><span class="cd-val" id="cd-min">--</span><span class="cd-unit">min</span></div>
            <div class="cd-cell"><span class="cd-val" id="cd-seg">--</span><span class="cd-unit">seg</span></div>
          </div>
          <div class="dash-card-footer">11.06.2026 · MÉXICO × ÁFRICA DO SUL</div>
        </div>
      </aside>
    </div>

    <!-- KPIs strip -->
    <div class="dash-kpis">
      <div class="dash-kpi">
        <span class="dash-kpi-num" data-count="48">48</span>
        <span class="dash-kpi-label">Seleções</span>
      </div>
      <div class="dash-kpi">
        <span class="dash-kpi-num" data-count="16">16</span>
        <span class="dash-kpi-label">Sedes</span>
      </div>
      <div class="dash-kpi">
        <span class="dash-kpi-num" data-count="104">104</span>
        <span class="dash-kpi-label">Jogos</span>
      </div>
      <div class="dash-kpi">
        <span class="dash-kpi-num" data-count="12">12</span>
        <span class="dash-kpi-label">Grupos</span>
      </div>
      <div class="dash-kpi">
        <span class="dash-kpi-num" data-count="3">3</span>
        <span class="dash-kpi-label">Países-sede</span>
      </div>
    </div>
  </section>

  <!-- ===== FEATURED MATCH ===== -->
  <% const featured = jogosAoVivo[0] || proximosJogos[0]; %>
  <% if (featured) { %>
  <section class="dash-section">
    <div class="dash-section-head">
      <h2 class="dash-section-title">
        <% if (jogosAoVivo[0]) { %>
          <span class="badge-ao-vivo">● AO VIVO</span>
        <% } else { %>
          <span class="dash-pill">Próximo</span>
        <% } %>
        Featured Match
      </h2>
      <a href="/jogos" class="dash-link">Ver todos →</a>
    </div>

    <div class="featured-match <%= jogosAoVivo[0] ? 'is-live' : '' %>">
      <div class="featured-side featured-home">
        <% if (featured.bandeirasCasa) { %>
          <img src="<%= featured.bandeirasCasa %>" alt="" class="featured-flag">
        <% } else { %>
          <div class="featured-flag featured-flag-fallback">⚽</div>
        <% } %>
        <div class="featured-team-name"><%= featured.timeCasa %></div>
        <div class="featured-team-pos">CASA</div>
      </div>

      <div class="featured-center">
        <div class="featured-status">
          <% if (jogosAoVivo[0]) { %>
            <span class="featured-live-dot"></span> <%= featured.statusLabel %>
          <% } else { %>
            <%= featured.data %>
          <% } %>
        </div>
        <div class="featured-placar">
          <% if (jogosAoVivo[0] && featured.placar && featured.placar !== '-') { %>
            <%= featured.placar %>
          <% } else { %>
            <span class="featured-vs">VS</span>
          <% } %>
        </div>
        <div class="featured-fase"><%= featured.fase || 'Fase de Grupos' %></div>
        <% if (featured.cidade) { %>
          <div class="featured-cidade">📍 <%= featured.cidade %></div>
        <% } %>
      </div>

      <div class="featured-side featured-away">
        <% if (featured.bandeiraFora) { %>
          <img src="<%= featured.bandeiraFora %>" alt="" class="featured-flag">
        <% } else { %>
          <div class="featured-flag featured-flag-fallback">⚽</div>
        <% } %>
        <div class="featured-team-name"><%= featured.timeFora %></div>
        <div class="featured-team-pos">FORA</div>
      </div>
    </div>
  </section>
  <% } %>

  <!-- ===== GRID DUPLA: PRÓXIMOS JOGOS + TOP BOLÃO ===== -->
  <section class="dash-grid-2">
    <div class="dash-col">
      <div class="dash-section-head">
        <h2 class="dash-section-title">Próximos Jogos</h2>
        <a href="/jogos" class="dash-link">Todos →</a>
      </div>

      <% if (proximosJogos.length === 0) { %>
        <div class="dash-empty">
          <div class="dash-empty-icon">⚽</div>
          <p class="dash-empty-text">Nenhum jogo agendado.</p>
        </div>
      <% } else { %>
        <div class="jogos-lista">
          <% proximosJogos.slice(0, 6).forEach(jogo => { %>
            <div class="card-jogo">
              <span class="jogo-status em_breve">Em breve</span>
              <div class="jogo-times">
                <div class="time-bloco">
                  <% if (jogo.bandeirasCasa) { %><img src="<%= jogo.bandeirasCasa %>" alt="" class="bandeira-mini"><% } %>
                  <span class="time-nome-jogo"><%= jogo.timeCasa %></span>
                </div>
                <span class="vs">vs</span>
                <div class="time-bloco">
                  <% if (jogo.bandeiraFora) { %><img src="<%= jogo.bandeiraFora %>" alt="" class="bandeira-mini"><% } %>
                  <span class="time-nome-jogo"><%= jogo.timeFora %></span>
                </div>
              </div>
              <div class="jogo-info">
                <span class="jogo-data"><%= jogo.data %></span>
                <span class="jogo-fase"><%= jogo.fase %></span>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>

    <div class="dash-col">
      <div class="dash-section-head">
        <h2 class="dash-section-title">Top do Bolão</h2>
        <a href="/ranking" class="dash-link">Completo →</a>
      </div>

      <% if (topRanking.length === 0) { %>
        <div class="dash-empty">
          <div class="dash-empty-icon">🏆</div>
          <p class="dash-empty-text">Bolão começa quando os jogos rolarem.</p>
          <% if (!usuario) { %>
            <a href="/cadastro" class="btn btn-primary btn-small">Cadastrar grátis</a>
          <% } %>
        </div>
      <% } else { %>
        <ol class="dash-ranking">
          <% topRanking.forEach((r, i) => { %>
            <li class="dash-rank-item dash-rank-<%= i + 1 %>">
              <span class="dash-rank-pos">
                <% if (i === 0) { %>🥇<% } else if (i === 1) { %>🥈<% } else if (i === 2) { %>🥉<% } else { %><%= i + 1 %><% } %>
              </span>
              <span class="dash-rank-nome"><%= r.nome %></span>
              <span class="dash-rank-pts"><%= r.total_pontos %><span class="dash-rank-pts-unit">pts</span></span>
            </li>
          <% }) %>
        </ol>
      <% } %>

      <div class="dash-fatos-card">
        <div class="dash-card-label">FATOS COPA 2026</div>
        <ul class="dash-fatos-list">
          <li><span class="dash-fatos-num">48</span>seleções de 6 confederações</li>
          <li><span class="dash-fatos-num">104</span>jogos em 3 países anfitriões</li>
          <li><span class="dash-fatos-num">16</span>estádios entre EUA, Canadá e México</li>
          <li><span class="dash-fatos-num">19/07</span>Final em Nova Jersey</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- ===== NOTÍCIAS ===== -->
  <section class="dash-section">
    <div class="dash-section-head">
      <h2 class="dash-section-title">Últimas Notícias</h2>
      <a href="/noticias" class="dash-link">Todas →</a>
    </div>

    <% if (noticias.length === 0) { %>
      <p class="text-muted">Nenhuma notícia disponível no momento.</p>
    <% } else { %>
      <div class="dash-noticias-grid">
        <% noticias.forEach((n, i) => { %>
          <a href="<%= n.url %>" target="_blank" rel="noopener noreferrer"
             class="card-noticia <%= n.ehCopa ? 'card-noticia-copa' : '' %> <%= i === 0 ? 'card-noticia-featured' : '' %>">
            <div class="noticia-meta">
              <% if (n.ehCopa) { %><span class="badge-copa-news">COPA 2026</span><% } %>
              <span class="noticia-fonte"><%= n.fonte %></span>
              <span class="noticia-data"><%= n.data %></span>
            </div>
            <h3 class="noticia-titulo"><%= n.titulo %></h3>
            <span class="noticia-externa">Ler matéria ↗</span>
          </a>
        <% }) %>
      </div>
    <% } %>
  </section>
</div>

<script>
(function() {
  const alvo = new Date('2026-06-11T22:00:00Z');
  function pad(n) { return String(n).padStart(2, '0'); }
  function atualizar() {
    const diff = alvo - new Date();
    if (diff <= 0) {
      const c = document.getElementById('countdown-container');
      if (c) c.style.display = 'none';
      return;
    }
    document.getElementById('cd-dias').textContent  = pad(Math.floor(diff / 86400000));
    document.getElementById('cd-horas').textContent = pad(Math.floor((diff % 86400000) / 3600000));
    document.getElementById('cd-min').textContent   = pad(Math.floor((diff % 3600000) / 60000));
    document.getElementById('cd-seg').textContent   = pad(Math.floor((diff % 60000) / 1000));
  }
  atualizar();
  setInterval(atualizar, 1000);
})();
</script>

<%- include('../partials/footer') %>
