<%- include('../partials/header') %>

<div class="container">
  <section class="dash-page-hero">
    <div class="dash-page-hero-text">
      <span class="dash-eyebrow"><span class="dash-eyebrow-dot"></span>BOLÃO COPA 2026</span>
      <h1 class="dash-page-title">Meus Palpites</h1>
      <p class="dash-page-sub">Faça ou edite seus palpites até <strong>1 hora antes</strong> de cada jogo · 5 pts placar exato · 2 pts resultado</p>
    </div>
  </section>

  <div class="dash-bolao-layout">
    <!-- Sidebar com stats do usuário -->
    <aside class="dash-bolao-sidebar">
      <div class="dash-bolao-pontos-card">
        <div class="dash-card-label"><span class="pulse-dot"></span>SUA PONTUAÇÃO</div>
        <div class="dash-bolao-pontos-num"><%= stats.total_pontos %></div>
        <div class="dash-bolao-pontos-unit">pontos totais</div>
      </div>

      <div class="dash-bolao-stats">
        <div class="dash-bolao-stat dash-bolao-stat-gold">
          <span class="dash-bolao-stat-num"><%= stats.placar_exatos %></span>
          <span class="dash-bolao-stat-label">⭐ Placar Exato</span>
          <span class="dash-bolao-stat-pts">+5 pts cada</span>
        </div>
        <div class="dash-bolao-stat dash-bolao-stat-green">
          <span class="dash-bolao-stat-num"><%= stats.resultados_certos %></span>
          <span class="dash-bolao-stat-label">✅ Resultado Certo</span>
          <span class="dash-bolao-stat-pts">+2 pts cada</span>
        </div>
        <div class="dash-bolao-stat dash-bolao-stat-red">
          <span class="dash-bolao-stat-num"><%= stats.erros %></span>
          <span class="dash-bolao-stat-label">❌ Errados</span>
          <span class="dash-bolao-stat-pts">0 pts</span>
        </div>
      </div>

      <div class="dash-bolao-progress">
        <div class="dash-card-label">PROGRESSO</div>
        <ul class="dash-bolao-progress-list">
          <li>
            <span class="dash-bolao-progress-label">Total palpitado</span>
            <span class="dash-bolao-progress-val"><%= stats.total_palpites %></span>
          </li>
          <li>
            <span class="dash-bolao-progress-label">Editáveis</span>
            <span class="dash-bolao-progress-val"><%= stats.editaveis %></span>
          </li>
          <li>
            <span class="dash-bolao-progress-label">Disponíveis</span>
            <span class="dash-bolao-progress-val"><%= stats.pendentes %></span>
          </li>
        </ul>
      </div>

      <a href="/ranking" class="btn btn-outline btn-small dash-bolao-cta">🏆 Ver ranking completo</a>
    </aside>

    <!-- Conteúdo principal -->
    <div class="dash-bolao-main">
      <% if (palpitesEditaveis && palpitesEditaveis.length > 0) { %>
      <section class="dash-section">
        <div class="dash-section-head">
          <h2 class="dash-section-title">
            <span class="dash-pill" style="color: var(--cor-accent); border-color: rgba(255,215,0,.25); background: rgba(255,215,0,.08)">EDITÁVEIS</span>
            Palpites Enviados
          </h2>
          <span class="dash-link"><%= palpitesEditaveis.length %> jogo(s)</span>
        </div>
        <div class="palpites-lista" id="palpites-editaveis">
          <% palpitesEditaveis.forEach(p => { %>
            <div class="card-palpite card-palpite-editavel" data-jogo-id="<%= p.jogo.id %>">
              <div class="palpite-jogo-info">
                <span class="palpite-fase"><%= p.jogo.fase %></span>
                <span class="palpite-data-hora"><%= p.jogo.data %></span>
              </div>
              <div class="palpite-times-row">
                <span class="palpite-time"><%= p.jogo.timeCasa %></span>
                <div class="palpite-placar-grupo">
                  <input type="number" class="input-placar" name="gols_casa" min="0" max="20"
                    value="<%= p.gols_casa %>" aria-label="Gols <%= p.jogo.timeCasa %>">
                  <span class="palpite-x">×</span>
                  <input type="number" class="input-placar" name="gols_fora" min="0" max="20"
                    value="<%= p.gols_fora %>" aria-label="Gols <%= p.jogo.timeFora %>">
                </div>
                <span class="palpite-time palpite-time-fora"><%= p.jogo.timeFora %></span>
              </div>
              <div class="palpite-acoes">
                <span class="palpite-atual-label">Palpite atual: <strong><%= p.gols_casa %> × <%= p.gols_fora %></strong></span>
                <button class="btn btn-small btn-outline btn-palpitar" data-jogo-id="<%= p.jogo.id %>">
                  Salvar edição
                </button>
              </div>
            </div>
          <% }) %>
        </div>
      </section>
      <% } %>

      <section class="dash-section">
        <div class="dash-section-head">
          <h2 class="dash-section-title">
            <span class="dash-pill">PALPITAR</span>
            Próximos Jogos
          </h2>
          <% if (jogos.length > 0) { %>
            <span class="dash-link"><%= jogos.length %> disponível(is)</span>
          <% } %>
        </div>
        <% if (jogos.length === 0) { %>
          <div class="dash-empty">
            <div class="dash-empty-icon">✅</div>
            <p class="dash-empty-text">Você já palpitou em todos os jogos disponíveis.</p>
          </div>
        <% } else { %>
          <div class="palpites-lista" id="palpites-lista">
            <% jogos.forEach(jogo => { %>
              <div class="card-palpite" data-jogo-id="<%= jogo.id %>">
                <div class="palpite-jogo-info">
                  <span class="palpite-fase"><%= jogo.fase %></span>
                  <span class="palpite-data-hora"><%= jogo.data %></span>
                  <% if (jogo.cidade) { %><span class="palpite-cidade"><%= jogo.cidade %></span><% } %>
                </div>
                <div class="palpite-times-row">
                  <span class="palpite-time"><%= jogo.timeCasa %></span>
                  <div class="palpite-placar-grupo">
                    <input type="number" class="input-placar" name="gols_casa" min="0" max="20"
                      placeholder="0" aria-label="Gols <%= jogo.timeCasa %>">
                    <span class="palpite-x">×</span>
                    <input type="number" class="input-placar" name="gols_fora" min="0" max="20"
                      placeholder="0" aria-label="Gols <%= jogo.timeFora %>">
                  </div>
                  <span class="palpite-time palpite-time-fora"><%= jogo.timeFora %></span>
                </div>
                <div class="palpite-acoes">
                  <button class="btn btn-small btn-primary btn-palpitar" data-jogo-id="<%= jogo.id %>">
                    Confirmar palpite
                  </button>
                </div>
              </div>
            <% }) %>
          </div>
        <% } %>
      </section>

      <section class="dash-section">
        <div class="dash-section-head">
          <h2 class="dash-section-title">
            <span class="dash-pill" style="color: var(--texto-terciario); border-color: var(--borda); background: rgba(255,255,255,.04)">HISTÓRICO</span>
            Palpites Encerrados
          </h2>
          <% if (palpites.length > 0) { %>
            <span class="dash-link"><%= palpites.length %> jogo(s)</span>
          <% } %>
        </div>
        <% if (palpites.length === 0) { %>
          <div class="dash-empty">
            <div class="dash-empty-icon">📊</div>
            <p class="dash-empty-text">Seus palpites de jogos encerrados aparecerão aqui.</p>
          </div>
        <% } else { %>
          <div class="dash-historico-wrap">
            <table class="tabela-historico">
              <thead>
                <tr>
                  <th>Jogo</th>
                  <th>Seu Palpite</th>
                  <th>Resultado</th>
                  <th>Pontos</th>
                </tr>
              </thead>
              <tbody>
                <% palpites.forEach(p => { %>
                  <tr>
                    <td><%= p.timeCasa %> × <%= p.timeFora %></td>
                    <td class="td-palpite"><%= p.gols_casa %> × <%= p.gols_fora %></td>
                    <td><%= p.resultado || '—' %></td>
                    <td>
                      <% if (p.pontos === 5) { %>
                        <span class="pontos-badge pontos-5">5 pts ⭐</span>
                      <% } else if (p.pontos === 2) { %>
                        <span class="pontos-badge pontos-2">2 pts</span>
                      <% } else if (p.pontos === 0) { %>
                        <span class="pontos-badge pontos-0">0 pts</span>
                      <% } else { %>
                        <span class="text-muted">—</span>
                      <% } %>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </section>
    </div>
  </div>
</div>
<script src="/js/palpites.js"></script>
<%- include('../partials/footer') %>
