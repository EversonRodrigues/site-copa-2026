<%- include('../partials/header') %>

<%
  const totalJogos = jogos.length;
  const aoVivo = jogos.filter(j => j.status === 'ao_vivo').length;
  const encerrados = jogos.filter(j => j.status === 'encerrado').length;
  const agendados = jogos.filter(j => j.status === 'em_breve').length;
  const fases = [
    { id: '', label: 'Todas' },
    { id: 'Rodada 1', label: 'Rodada 1' },
    { id: 'Rodada 2', label: 'Rodada 2' },
    { id: 'Rodada 3', label: 'Rodada 3' },
    { id: 'Oitavas de Final', label: 'Oitavas' },
    { id: 'Quartas de Final', label: 'Quartas' },
    { id: 'Semifinal', label: 'Semis' },
    { id: '3º Lugar', label: '3º Lugar' },
    { id: 'Final', label: 'Final' }
  ];
%>

<div class="container">
  <!-- Hero compacto -->
  <section class="dash-page-hero">
    <div class="dash-page-hero-text">
      <span class="dash-eyebrow"><span class="dash-eyebrow-dot"></span>FIFA WC 2026 · CALENDÁRIO</span>
      <h1 class="dash-page-title">Jogos</h1>
      <p class="dash-page-sub">Calendário completo dos 104 jogos · placares ao vivo via TheSportsDB</p>
    </div>

    <div class="dash-mini-kpis">
      <div class="dash-mini-kpi">
        <span class="dash-mini-kpi-num"><%= totalJogos %></span>
        <span class="dash-mini-kpi-label">Total</span>
      </div>
      <div class="dash-mini-kpi dash-mini-kpi-live">
        <span class="dash-mini-kpi-num"><%= aoVivo %></span>
        <span class="dash-mini-kpi-label"><span class="pulse-dot"></span>Ao Vivo</span>
      </div>
      <div class="dash-mini-kpi">
        <span class="dash-mini-kpi-num"><%= agendados %></span>
        <span class="dash-mini-kpi-label">Agendados</span>
      </div>
      <div class="dash-mini-kpi">
        <span class="dash-mini-kpi-num"><%= encerrados %></span>
        <span class="dash-mini-kpi-label">Encerrados</span>
      </div>
    </div>
  </section>

  <!-- Tabs de fase -->
  <nav class="dash-tabs" aria-label="Filtrar por fase">
    <% fases.forEach(f => { %>
      <a href="<%= f.id ? '/jogos?fase=' + encodeURIComponent(f.id) : '/jogos' %>"
         class="dash-tab <%= faseSelecionada === f.id ? 'dash-tab-active' : '' %>">
        <%= f.label %>
      </a>
    <% }) %>
  </nav>

  <% if (jogos.length === 0) { %>
    <div class="dash-empty">
      <div class="dash-empty-icon">🔍</div>
      <p class="dash-empty-text">Nenhum jogo encontrado para esta fase.</p>
      <a href="/jogos" class="btn btn-outline btn-small">Ver todos</a>
    </div>
  <% } else { %>
    <div class="dash-jogos-grid">
      <% jogos.forEach(jogo => { %>
        <article class="dash-match <%= jogo.status === 'ao_vivo' ? 'is-live' : '' %>">
          <header class="dash-match-head">
            <span class="jogo-status <%= jogo.status %>"><%= jogo.statusLabel %></span>
            <span class="dash-match-fase"><%= jogo.fase %></span>
          </header>

          <div class="dash-match-body">
            <div class="dash-match-team">
              <% if (jogo.bandeirasCasa) { %>
                <img src="<%= jogo.bandeirasCasa %>" alt="" class="dash-match-flag">
              <% } else { %>
                <div class="dash-match-flag dash-match-flag-fallback">⚽</div>
              <% } %>
              <span class="dash-match-team-name"><%= jogo.timeCasa %></span>
            </div>

            <div class="dash-match-score">
              <% if (jogo.status === 'encerrado' || jogo.status === 'ao_vivo') { %>
                <span class="dash-match-score-num"><%= jogo.placar %></span>
              <% } else { %>
                <span class="dash-match-vs">VS</span>
              <% } %>
            </div>

            <div class="dash-match-team dash-match-team-away">
              <% if (jogo.bandeiraFora) { %>
                <img src="<%= jogo.bandeiraFora %>" alt="" class="dash-match-flag">
              <% } else { %>
                <div class="dash-match-flag dash-match-flag-fallback">⚽</div>
              <% } %>
              <span class="dash-match-team-name"><%= jogo.timeFora %></span>
            </div>
          </div>

          <footer class="dash-match-foot">
            <span class="dash-match-data">📅 <%= jogo.data %></span>
            <% if (jogo.cidade) { %>
              <span class="dash-match-cidade">📍 <%= jogo.cidade %></span>
            <% } %>
          </footer>
        </article>
      <% }) %>
    </div>
  <% } %>
</div>
<%- include('../partials/footer') %>
