<%- include('../partials/header') %>
<div class="container">
  <div class="page-header">
    <h1 class="page-title">Jogos</h1>
    <p class="subtitle">Copa do Mundo 2026 — Calendário completo</p>
  </div>

  <form class="filtro-form" method="GET" action="/jogos">
    <select name="fase" class="form-input filtro-select" onchange="this.form.submit()" aria-label="Filtrar por fase">
      <option value="">Todas as fases</option>
      <optgroup label="Fase de Grupos">
        <option value="Rodada 1" <%= faseSelecionada === 'Rodada 1' ? 'selected' : '' %>>Rodada 1</option>
        <option value="Rodada 2" <%= faseSelecionada === 'Rodada 2' ? 'selected' : '' %>>Rodada 2</option>
        <option value="Rodada 3" <%= faseSelecionada === 'Rodada 3' ? 'selected' : '' %>>Rodada 3</option>
      </optgroup>
      <optgroup label="Mata-mata">
        <option value="Oitavas de Final" <%= faseSelecionada === 'Oitavas de Final' ? 'selected' : '' %>>Oitavas de Final</option>
        <option value="Quartas de Final" <%= faseSelecionada === 'Quartas de Final' ? 'selected' : '' %>>Quartas de Final</option>
        <option value="Semifinal" <%= faseSelecionada === 'Semifinal' ? 'selected' : '' %>>Semifinais</option>
        <option value="3º Lugar" <%= faseSelecionada === '3º Lugar' ? 'selected' : '' %>>3º Lugar</option>
        <option value="Final" <%= faseSelecionada === 'Final' ? 'selected' : '' %>>Final</option>
      </optgroup>
    </select>
  </form>

  <% if (jogos.length === 0) { %>
    <div class="empty-state">
      <div class="empty-state-icon">🔍</div>
      <div class="empty-state-titulo">Nenhum jogo encontrado</div>
      <p>Tente outro filtro ou <a href="/jogos">veja todos os jogos</a>.</p>
    </div>
  <% } else { %>
    <div class="jogos-lista">
      <% jogos.forEach(jogo => { %>
        <div class="card-jogo">
          <span class="jogo-status <%= jogo.status %>"><%= jogo.statusLabel %></span>
          <div class="jogo-times">
            <div class="time-bloco">
              <% if (jogo.bandeirasCasa) { %><img src="<%= jogo.bandeirasCasa %>" alt="" class="bandeira-mini"><% } %>
              <span class="time-nome-jogo"><%= jogo.timeCasa %></span>
            </div>
            <% if (jogo.status === 'encerrado' || jogo.status === 'ao_vivo') { %>
              <span class="placar"><%= jogo.placar %></span>
            <% } else { %>
              <span class="vs">vs</span>
            <% } %>
            <div class="time-bloco">
              <% if (jogo.bandeiraFora) { %><img src="<%= jogo.bandeiraFora %>" alt="" class="bandeira-mini"><% } %>
              <span class="time-nome-jogo"><%= jogo.timeFora %></span>
            </div>
          </div>
          <div class="jogo-info">
            <span class="jogo-data"><%= jogo.data %></span>
            <span class="jogo-fase"><%= jogo.fase %></span>
            <% if (jogo.cidade) { %><span class="jogo-cidade">📍 <%= jogo.cidade %></span><% } %>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>
<%- include('../partials/footer') %>
